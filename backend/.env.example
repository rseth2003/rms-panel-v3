# Copy this file to .env and fill in your real values
PORT=3000

# MySQL/MariaDB connection
DB_HOST=localhost
DB_USER=rms_panel
DB_PASSWORD=change_this_password
DB_NAME=rms_panel

# JWT secret - generate a long random string
JWT_SECRET=change_this_to_a_long_random_string

# Restrict the API to only accept requests from your real deployed frontend
# domain once you're live (e.g. https://panel.yourdomain.com). Leave as *
# only during local testing - never in production.
FRONTEND_ORIGIN=*

# Initial super admin account (created automatically on first run if no admin exists)
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=change_this_password

# Path to the wrapper script that talks to your udp manager
UDP_WRAPPER_PATH=/etc/UDPCustom/udp-api-wrapper.sh
